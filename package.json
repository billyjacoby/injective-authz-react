    "@injectivelabs/utils": "^1.14.13",
    "@injectivelabs/wallet-ts": "^1.14.13",
    "hono": "^4.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-qr-code": "^2.0.15",
    "react-select": "^5.8.0",
    "tiny-secp256k1": "^2.2.3",
    "tsup": "^8.2.3",
